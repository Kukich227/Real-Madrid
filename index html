<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Real Madrid Club</title>
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <header class="nav">
    <div class="logo-wrap">
      <div class="logo">RM</div>
      <div>
        <div class="brand-title">Real Madrid Club</div>
        <div class="brand-subtitle" id="brandSubtitle">Премиальный клубный сайт</div>
      </div>
    </div>

    <div class="controls">
      <button type="button" id="themeBtn">🌙</button>
      <button type="button" id="langBtn">RU/EN</button>
      <button type="button" id="adminOpenBtn">Admin</button>
      <button type="button" id="logoutBtn" class="hidden">Logout</button>
    </div>
  </header>

  <main class="container">
    <section class="hero">
      <div class="hero-card">
        <div class="hero-badge" id="heroBadge">Hala Madrid</div>
        <h1 id="heroTitle">Real Madrid</h1>
        <p id="heroText">
          Современный сайт клуба с красивым интерфейсом, полем состава, новостями, трансферами и удобной админкой.
        </p>
      </div>

      <div class="stats-grid">
        <div class="stat-card">
          <span id="statPlayersLabel">Игроки</span>
          <strong id="playersCount">0</strong>
        </div>
        <div class="stat-card">
          <span id="statTransfersLabel">Трансферы</span>
          <strong id="transfersCount">0</strong>
        </div>
        <div class="stat-card">
          <span id="statNewsLabel">Новости</span>
          <strong id="newsCount">0</strong>
        </div>
        <div class="stat-card">
          <span id="statMatchesLabel">Матчи</span>
          <strong id="scheduleCount">0</strong>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <h2 id="playersTitle">Игроки</h2>
        <input id="search" class="search" placeholder="Поиск игрока" />
      </div>
      <div id="players" class="cards-grid"></div>
    </section>

    <section class="section">
      <div class="section-head">
        <h2 id="lineupTitle">Состав</h2>
      </div>

      <div class="field-wrap">
        <div class="field">
          <div class="center-line"></div>
          <div class="center-circle"></div>

          <div class="pos lw" id="lw">
            <span class="pos-label">ЛВ</span>
            <span class="pos-name">—</span>
          </div>

          <div class="pos rw" id="rw">
            <span class="pos-label">ПВ</span>
            <span class="pos-name">—</span>
          </div>

          <div class="pos cm" id="cm">
            <span class="pos-label">ЦП</span>
            <span class="pos-name">—</span>
          </div>

          <div class="pos gk" id="gk">
            <span class="pos-label">ГК</span>
            <span class="pos-name">—</span>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <h2 id="transfersTitle">Трансферы</h2>
      </div>
      <div id="transfers" class="cards-grid two-col"></div>
    </section>

    <section class="section">
      <div class="section-head">
        <h2 id="scheduleTitle">Расписание</h2>
      </div>
      <div id="schedule" class="cards-grid two-col"></div>
    </section>

    <section class="section">
      <div class="section-head">
        <h2 id="newsTitle">Новости</h2>
      </div>
      <div id="news" class="cards-grid two-col"></div>
    </section>

    <section id="adminPanel" class="admin hidden">
      <div class="admin-header">
        <h2 id="adminTitle">⚙️ Админ-панель</h2>
        <div class="admin-note" id="adminNote">Добавляй, редактируй и удаляй всё</div>
      </div>

      <div class="admin-grid">
        <div class="admin-box">
          <h3 id="adminPlayersTitle">Игроки</h3>
          <input id="pname" placeholder="Имя игрока" />
          <input id="ppos" placeholder="Позиция" />
          <button type="button" id="addPlayerBtn">Добавить игрока</button>
        </div>

        <div class="admin-box">
          <h3 id="adminLineupTitle">Состав</h3>
          <input id="lpos" placeholder="Позиция: lw / rw / cm / gk" />
          <input id="lname" placeholder="Имя игрока" />
          <button type="button" id="setLineupBtn">Установить в состав</button>
        </div>

        <div class="admin-box">
          <h3 id="adminTransfersTitle">Трансферы</h3>
          <input id="tname" placeholder="Игрок" />
          <input id="tfrom" placeholder="Из какого клуба" />
          <button type="button" id="addTransferBtn">Добавить трансфер</button>
        </div>

        <div class="admin-box">
          <h3 id="adminScheduleTitle">Расписание</h3>
          <input id="sname" placeholder="Соперник / матч" />
          <input id="sdate" placeholder="Дата" />
          <button type="button" id="addMatchBtn">Добавить матч</button>
        </div>

        <div class="admin-box">
          <h3 id="adminNewsTitle">Новости</h3>
          <input id="ntitle" placeholder="Заголовок новости" />
          <button type="button" id="addNewsBtn">Добавить новость</button>
        </div>
      </div>
    </section>
  </main>

  <div id="modal" class="modal hidden">
    <div class="modal-box">
      <h3 id="modalTitle">Вход в админку</h3>
      <p id="modalText">Введите пароль администратора</p>
      <input id="pass" type="password" placeholder="Пароль" />
      <div class="modal-actions">
        <button type="button" id="loginBtn">Войти</button>
        <button type="button" id="closeModalBtn" class="secondary">Закрыть</button>
      </div>
    </div>
  </div>

  <script src="script.js"></script>
</body>
</html>
